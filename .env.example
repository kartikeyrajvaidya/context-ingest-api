APP_NAME="ContextIngest API"
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

POSTGRES_DB=context_ingest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

DB_CONNECTION_URI=postgresql://postgres:password@localhost:5432/context_ingest
DB_CONNECTION_URI_ASYNCPG=postgresql+asyncpg://postgres:password@localhost:5432/context_ingest
DOCKER_DB_CONNECTION_URI=postgresql://postgres:password@postgres:5432/context_ingest
DOCKER_DB_CONNECTION_URI_ASYNCPG=postgresql+asyncpg://postgres:password@postgres:5432/context_ingest
SCHEMA_NAME=public
DB_STATEMENT_TIMEOUT=3000
DB_APPLICATION_NAME=context-ingest-api
SQLALCHEMY_ECHO=F
SQLALCHEMY_ECHO_POOL=F

OPENAI_API_KEY=
OPENAI_ANSWER_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_TIMEOUT_SECONDS=20

CHUNK_TOKEN_SIZE=500
CHUNK_TOKEN_OVERLAP=75
RETRIEVAL_VECTOR_CANDIDATES=20
RETRIEVAL_FULLTEXT_CANDIDATES=20
RETRIEVAL_TOP_K=5
CONVERSATION_HISTORY_TURN_LIMIT=10

RATE_LIMIT_IP_PER_MINUTE=5
RATE_LIMIT_SESSION_PER_HOUR=15
RATE_LIMIT_CONVERSATION_MAX_TURNS=10

# Safety gate — regex + cheap LLM classifier running before the main LLM call.
# Catches prompt-injection and jailbreak attempts. Set to false to disable.
SAFETY_ENABLED=true
# Model used for the classifier call. Any cheap chat-completions-capable model.
SAFETY_LLM_MODEL=gpt-4o-mini
